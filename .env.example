# Generate at: https://login.tailscale.com/admin/settings/keys
# Use: reusable=true, ephemeral=false, preauthorized=true, tags=tag:exit
TS_AUTHKEY=tskey-auth-REPLACE_ME

TS_HOSTNAME=tsroute-dev
TS_USERSPACE=true

GRAFANA_ADMIN_PASSWORD=changeme

# Set these AFTER you complete the AdGuard setup wizard at http://<tailnet-ip>:3000
# Then `make restart-exporter` to pick them up.
ADGUARD_USER=admin
ADGUARD_PASSWORD=changeme
